# LiveKit Cloud credentials
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project-subdomain.livekit.cloud

# Optional overrides
LIVEKIT_AGENT_NAME=conversational-cv-livekit
NEXT_PUBLIC_LIVEKIT_AGENT_NAME=conversational-cv-livekit
NEXT_PUBLIC_CONOR_PHONE_NUMBER=
NEXT_PUBLIC_CONOR_PHONE_LABEL=Call real Conor

# LiveKit Inference voice pipeline
LIVEKIT_INFERENCE_STT_MODEL=deepgram/nova-3:en
LIVEKIT_INFERENCE_LLM_MODEL=openai/gpt-5.3-chat-latest
LIVEKIT_INFERENCE_TTS_MODEL=cartesia/sonic-3:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
